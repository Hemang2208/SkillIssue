# Copy this file to .env and fill in your values

# Groq API (for AI skill generation)
VITE_GROQ_API_KEY=

# MongoDB Atlas — https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGODB_URI=
# MONGODB_DB=skillissue  # optional, defaults to "skillissue"

# Supabase — https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
